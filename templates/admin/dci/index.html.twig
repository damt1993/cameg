{% extends 'base.html.twig' %}

{% set action = app.current_route=="app_admin_dci" ? "Créer un nouveau DCI" : "Editer le DCI" %}

{% block title %}Hello DCIController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h2>{{action}}</h2>

    <div class="">
        {{form_start(form)}}
            {% if action == "Editer le DCI" %}
            {{form_row(form.name, {label : currentDci.name})}}
            {% else %}
            {{form_row(form.name, {label : "Nom du DCI"})}}
            {% endif %}
            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a href="{{path('app_admin_dci')}}" class="btn btn-secondary">Annuler</a>
        {{form_end(form)}}
    </div>
    <section class="mt-5">
        <h2>Liste des DCI</h2>

        <div class="mt-3">
            {% if dci is not null %}
            <ul>
                {{pagerfanta(dci)}}
                {% for item in dci %}
                    <li>
                        {{item.name}}
                        <a href="{{path('app_admin_dci_edit', {id: item.id})}}" class="btn btn-outline-primary">Editer</a>
                        <a href="" class="btn btn-outline-danger">Supprimer</a>
                    </li>
                {% else %}
                    <p>Aucun DCI disponible actuellement.</p>
                {% endfor %}
                {{pagerfanta(dci)}}
            </ul>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
