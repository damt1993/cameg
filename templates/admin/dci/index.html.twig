{% extends 'base.html.twig' %}

{% block title %}Hello DCIController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h2>Créér un nouveau DCI</h2>

    <div class="">
        {{form_start(form)}}
            {{form_row(form.name, {label : "Nom du DCI"})}}
            <button type="submit" class="btn btn-primary">Enregistrer</button>
        {{form_end(form)}}
    </div>
    <section class="mt-5">
        <h2>Liste des DCI</h2>

        <div class="mt-3">
            {% if dci is not null %}
            <ul>
                {{pagerfanta(dci)}}
                {% for item in dci %}
                    <li>
                        {{item.name}}
                        <a href="" class="btn btn-outline-primary">Editer</a>
                        <a href="" class="btn btn-outline-danger">Supprimer</a>
                    </li>
                {% else %}
                    <p>Aucun DCI disponible actuellement.</p>
                {% endfor %}
                {{pagerfanta(dci)}}
            </ul>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}
