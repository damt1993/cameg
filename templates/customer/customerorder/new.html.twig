{% extends 'base.html.twig' %}

{% block title %}Hello CustomerOrderController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">

  <section class="orderCreator">
    <h4 class=" text-center">Nouvelle commande</h4>
    {% include "components/searchbarAutocomplete.html.twig" %}
  </section>

    <section class="orderChoice">
        <form action="">
            <div class="mb-3 row d-flex">
                <div class="col-md-8 product">
                    Nom du produit : <span></span>
                </div>
                <div class="col-md-3 d-flex OrderQuantityField">
                    Quantité {% include "components/quantityBox.html.twig" %}
                </div>
            </div>
            <div class="mb-3 row d-flex justify-content-between">
                <div class="col-md-3 price">
                    P. Achat : <span></span>
                </div>
                <div class="col-md-3 publicPrice">
                    P. Public : <span></span>
                </div>
                <div class="col-md-6 peromptAt">
                    Date de péremption : <span></span>
                </div>
            </div>
            <div class=" text-end">
                <button type="submit" class="btn btn-primary">Ajouter au panier</button>
            </div>
        </form>
    </section>

    <section class="card mt-5">
        <div class="card-header">
            <div class="row">
                <div class="col-1"></div>
                <div class="col-3"><h5>Nom du produit</h5></div>
                <div class="col-2 text-center"><h5>Quantité</h5></div>
                <div class="col-2"><h5>P. Achat</h5></div>
                <div class="col-2"><h5>P. Public</h5></div>
                <div class="col-2"><h5>Montant</h5></div>
            </div>
        </div>
        <div class="orderList card-body border-primary">
            {% for orderItem in phpOrderItem %}
                <div id="item{{orderItem['id']}}" class="row mb-3">
                    <div class="col-4">
                        <button class="btn btn-outline-danger">x</button>
                        {{ orderItem['name'] }}
                    </div>
                    <div class="col-2 orderQuantity">
                        <div class="quantityBox">
                            <div class="input-group">
                                <span class="input-group-btn input-group-prepend">
                                    <button class="btn btn-dark remove" type="button">-</button>
                                </span>
                                <input type="number" name="quantity" id="input{{ orderItem['id'] }}" class="form-control" value="{{ orderItem['quantity'] }}" min="0" width="100">
                                <span class="input-group-btn intup-group-append">
                                    <button class="btn btn-dark add" type="button">+</button>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="col-2 orderPrice">{{ orderItem['price'] }}</div>
                    <div class="col-2 orderPublicPrice">{{ orderItem['publicPrice'] }}</div>
                    <div class="col-2 orderValue">{{ orderItem['price']*orderItem['quantity'] }}</div>
                </div>
            {% endfor %}
        </div>
        <div class="card-footer m-2 text-end">
            <a href="" class="btn btn-danger me-5">Supprimer la commande</a>
            <a href="" class="btn btn-warning me-5">Mettre en attente</a>
            <a href="" class="btn btn-success me-5">Valider la commande</a>
        </div>
    </section>
</div>
<script>
    const jsProduct = {{ product|json_encode|raw }};
    const orderItemer = {{ orderItemer|raw }};
</script>
{% endblock %}

