{% extends 'base.html.twig' %}


{% block title %}{{customer.organisationName}}-{% endblock %}

{% block body %}
<!-- Create a navbar item for all customer actions space -->
<div class="example-wrapper mt-0">
    <section class="bg-white text-center pb-1 pt-2">
        <h1> {{ customer.organisationName }} </h1>
        <p>Contact : {{ customer.contact}} </p>
    </section>
    <nav class="navbar navbar-expand navbar-dark bg-dark p-0 d-flex justify-content-between">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a href="{{path('app_customer_customerdata_edit', {id = customer})}}" class="nav-link">Profil</a>
            </li>
            <li class="nav-item dropdown">
                <button class="nav-link dropdown-toggle" id="navDropdownMenu" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">Commandes</button>
                <div class="dropdown-menu m-0 p-0 bg-dark" aria-labelledby="navDropdownMenu" id="navDropdownMenu">
                    <a href="{{path('app_customer_customerorder_new')}}" class="dropdown-item text-light"><i class="bi bi-cart-dash"></i> {{ newOrderButton }}</a>
                    <a href="#" class="dropdown-item text-light">Commande en attente</a>
                    <a href="#" class="dropdown-item text-light">Historique de vos commandes</a>
                </div>
            </li>
            <li class="nav-item">
                <a href="" class="nav-link">Nos produits</a>
            </li>
            <li class="nav-item">
                <a href="" class="nav-link">Documents</a>
            </li>
        </ul>
        <a href="#" class="btn btn-danger mx-3">Se déconnecter</a>
    </nav>
    {% block section %}{% endblock section %}

</div>

{% endblock %}
